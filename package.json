{
  "name": "clockwork",
  "title": "Clockwork",
  "description": "Manage clockwork project sessions across your codebase",
  "icon": "command-icon.svg",
  "author": "space",
  "license": "MIT",
  "version": "1.0.0",
  "commands": [
    {
      "name": "browse-sessions",
      "title": "Clockwork",
      "subtitle": "Sessions",
      "description": "View and manage clockwork sessions across all projects",
      "mode": "view",
      "keywords": ["clockwork", "sessions", "projects", "status", "state"]
    },
    {
      "name": "manage-projects",
      "title": "Manage Projects",
      "subtitle": "Clockwork",
      "description": "View, add, and remove tracked clockwork projects",
      "mode": "view",
      "keywords": ["clockwork", "manage", "projects", "add", "remove"]
    }
  ],
  "preferences": [
    {
      "name": "defaultEditor",
      "type": "dropdown",
      "required": false,
      "title": "Default Editor",
      "description": "Editor to open projects with",
      "default": "code",
      "data": [
        { "title": "VS Code", "value": "code" },
        { "title": "Cursor", "value": "cursor" },
        { "title": "Zed", "value": "zed" },
        { "title": "Sublime Text", "value": "subl" }
      ]
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.104.11",
    "js-yaml": "^4.1.1"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^2.1.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0"
  },
  "scripts": {
    "build": "ray build",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint",
    "publish": "ray publish"
  }
}
